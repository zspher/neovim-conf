{
  "flake": {
    "prefix": "flake",
    "body": [
      "{",
      "  inputs.nixpkgs.url = \"github:NixOS/nixpkgs/nixpkgs-unstable\";",
      "",
      "  outputs =",
      "    { nixpkgs, ... }:",
      "    let",
      "      inherit (nixpkgs) lib;",
      "      perSystem = lib.genAttrs [",
      "        \"x86_64-linux\"",
      "        \"aarch64-linux\"",
      "        \"x86_64-darwin\"",
      "        \"aarch64-darwin\"",
      "      ];",
      "       $0",
      "    in",
      "    {",
      "      devShells = perSystem (",
      "        system:",
      "        let",
      "          pkgs = nixpkgs.legacyPackages.\\${system};",
      "        in",
      "        {",
      "          default = pkgs.${2|mkShell,mkShellNoCC|} {",
      "            packages = with pkgs; [",
      "              $1",
      "            ];",
      "          };",
      "        }",
      "      );",
      "    };",
      "}"
    ]
  },
  "All Systems": {
    "prefix": "persa",
    "body": "perSystem = lib.genAttrs lib.systems.flakeExposed"
  },
  "pkgs": {
    "prefix": "pkgs =",
    "body": "pkgs = nixpkgs.legacyPackages.\\${system};"
  }
}
